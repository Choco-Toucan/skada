<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.skada.mng.mapper.MetricMapper">

    <resultMap id="BaseMap" type="com.skada.mng.model.Metric">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="name" property="name"/>
        <result column="code" property="code"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
    </resultMap>

    <select id="findByTenantId" resultMap="BaseMap">
        SELECT * FROM metric WHERE tenant_id = #{tenantId} ORDER BY id DESC
    </select>

    <select id="findById" resultMap="BaseMap">
        SELECT * FROM metric WHERE id = #{id}
    </select>

    <select id="findByTenantIdAndCode" resultMap="BaseMap">
        SELECT * FROM metric WHERE tenant_id = #{tenantId} AND code = #{code} LIMIT 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO metric (tenant_id, name, code, description, create_by, update_by)
        VALUES (#{tenantId}, #{name}, #{code}, #{description}, #{createBy}, #{updateBy})
    </insert>

    <update id="update">
        UPDATE metric
        SET name = #{name},
            code = #{code},
            description = #{description},
            update_by = #{updateBy}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM metric WHERE id = #{id}
    </delete>

    <select id="findAllWithPage" resultMap="BaseMap">
        SELECT * FROM metric ORDER BY id DESC LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM metric
    </select>

    <select id="findByIds" resultMap="BaseMap">
        SELECT * FROM metric WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
